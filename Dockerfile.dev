# Dockerfile.dev - শুধু ডেভেলপমেন্টের জন্য (hot reload সহ)
FROM node:22-alpine

WORKDIR /app

ENV CI=true
ENV HUSKY=0

RUN corepack enable && corepack prepare pnpm@10.20.0 --activate

# শুধু dependency ফাইলগুলো আগে কপি করা হচ্ছে, যাতে Docker layer caching কাজ করে
# (code change করলে এই স্টেপ আবার রান হবে না, শুধু dependency change হলে হবে)
COPY package*.json pnpm-lock.yaml pnpm-workspace.yaml ./

RUN pnpm install --frozen-lockfile

# বাকি কোড এখানে কপি হচ্ছে, কিন্তু dev মোডে volume mount এটাকে override করে দেবে
COPY . .

EXPOSE 5000

# NestJS watch mode - কোড চেঞ্জ হলেই অটো রিস্টার্ট হবে
CMD ["pnpm", "run", "start:dev"]